<view class="page-wrap" bindtouchstart="onTouchStart" bindtouchend="onTouchEnd">

  <!-- Month Navigator -->
  <view class="month-nav">
    <!-- 左侧：年上月下 -->
    <view class="nav-col">
      <view class="nav-btn nav-btn-sm" bindtap="prevYear">
        <text class="nav-arrow-sm">‹‹</text>
      </view>
      <view class="nav-btn" bindtap="prevMonth">
        <text class="nav-arrow">‹</text>
      </view>
    </view>

    <view class="month-title-wrap" bindtap="goToToday">
      <text class="month-year">{{currentYear}}</text>
      <text class="month-num">{{currentMonth < 10 ? '0' + currentMonth : currentMonth}}月</text>
    </view>

    <!-- 右侧：年上月下 -->
    <view class="nav-col">
      <view class="nav-btn nav-btn-sm" bindtap="nextYear">
        <text class="nav-arrow-sm">››</text>
      </view>
      <view class="nav-btn" bindtap="nextMonth">
        <text class="nav-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- Weekday headers -->
  <view class="weekday-header">
    <text
      wx:for="{{weekdays}}"
      wx:key="index"
      class="weekday-label {{index === 0 || index === 6 ? 'weekend-label' : ''}}"
    >{{item}}</text>
  </view>

  <!-- Calendar Grid -->
  <view class="calendar-grid" wx:if="{{!isLoading}}">
    <view
      wx:for="{{calendarDays}}"
      wx:key="key"
      class="day-cell {{item.empty ? 'empty' : ''}} {{item.isToday ? 'today' : ''}} {{item.isHoliday ? 'holiday' : ''}} {{item.isWeekend ? 'weekend' : ''}} {{item.isWorkday ? 'workday-makeup' : ''}} {{item.date === selectedDate ? 'selected' : ''}}"
      bindtap="onDayTap"
      data-date="{{item.date}}"
    >
      <view wx:if="{{!item.empty}}" class="day-inner">
        <!-- Day number -->
        <text class="day-num">{{item.day}}</text>

        <!-- Holiday name or lunar text -->
        <text wx:if="{{item.holidayName}}" class="day-festival festival-{{item.holidayCategory}}">{{item.holidayName}}</text>
        <text wx:elif="{{item.lunarText}}" class="day-lunar">{{item.lunarText}}</text>

        <!-- Workday makeup badge -->
        <view wx:if="{{item.isWorkday}}" class="makeup-badge">
          <text class="makeup-text">班</text>
        </view>

        <!-- Dot markers -->
        <view class="day-dots" wx:if="{{item.markers.length > 0}}">
          <view
            wx:for="{{item.markers}}"
            wx:key="index"
            wx:for-item="marker"
            class="dot"
            style="background: {{marker.color}};"
          ></view>
        </view>
      </view>
    </view>
  </view>

  <!-- Loading skeleton -->
  <view class="calendar-grid loading-grid" wx:if="{{isLoading}}">
    <view wx:for="{{42}}" wx:key="index" class="day-cell skeleton"></view>
  </view>

  <!-- Legend -->
  <view class="legend">
    <view class="legend-item">
      <view class="legend-dot" style="background:#EF5350;"></view>
      <text class="legend-text">节假日</text>
    </view>
    <view class="legend-item">
      <view class="legend-dot" style="background:#00BCD4;"></view>
      <text class="legend-text">我的事件</text>
    </view>
  </view>

  <!-- Day detail half sheet -->
  <view class="overlay" wx:if="{{showDaySheet}}" bindtap="closeDaySheet"></view>
  <view class="day-sheet {{showDaySheet ? 'show' : ''}}">
    <view class="sheet-handle"></view>
    <view class="sheet-date-header">
      <text class="sheet-date">{{selectedDate}}</text>
      <view class="add-event-btn" bindtap="onAddEvent">
        <text class="add-event-text">+ 添加关注</text>
      </view>
    </view>

    <scroll-view class="sheet-events" scroll-y>
      <view wx:if="{{selectedDayEvents.length === 0}}" class="no-events">
        <text class="no-events-text">这天没有特别的事件</text>
        <text class="no-events-sub">点击上方按钮添加</text>
      </view>

      <view
        wx:for="{{selectedDayEvents}}"
        wx:key="index"
        class="sheet-event-item"
      >
        <view class="event-color-bar" style="background: {{item.color}};"></view>
        <view class="event-info">
          <text class="event-info-name">{{item.name}}</text>
          <view class="event-info-meta">
            <text class="event-category-tag" style="color: {{item.color}};">{{item.categoryLabel}}</text>
            <text class="event-days-text">{{item.daysText}}</text>
            <!-- 节假日：一键添加为关注事件（内联，避免溢出） -->
            <view
              wx:if="{{item.isHoliday}}"
              class="holiday-add-btn"
              catchtap="onAddHolidayEvent"
              data-name="{{item.name}}"
              data-date="{{selectedDate}}"
            >
              <text class="holiday-add-text">+ 添加</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- Month Event Groups -->
  <view class="month-events-section" wx:if="{{monthEventGroups.length > 0}}">
    <view class="mes-title">本月事件</view>
    <view
      wx:for="{{monthEventGroups}}"
      wx:key="category"
      wx:for-item="group"
      class="mes-group"
    >
      <!-- Group header -->
      <view class="mes-group-header">
        <view class="mes-group-dot" style="background: {{group.color}};"></view>
        <text class="mes-group-label">{{group.label}}</text>
      </view>
      <!-- Event rows -->
      <view
        wx:for="{{group.events}}"
        wx:key="date"
        wx:for-item="ev"
        class="mes-event-row"
      >
        <text class="mes-event-name">{{ev.name}}</text>
        <text class="mes-event-date">{{ev.date}}</text>
        <text class="mes-event-days mes-days-{{ev.daysClass}}">{{ev.daysText}}</text>
      </view>
    </view>
  </view>

  <view style="height: 40rpx;"></view>
</view>
