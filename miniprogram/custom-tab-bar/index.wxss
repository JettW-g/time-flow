.tab-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  height: 110rpx;
  display: flex;
  align-items: stretch;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(10, 15, 30, 0.92);
  backdrop-filter: blur(24rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  z-index: 999;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  position: relative;
  transition: opacity 0.2s;
}

.tab-text {
  font-size: 20rpx;
  color: #475569;
  font-weight: 500;
  letter-spacing: 1rpx;
  transition: color 0.2s;
}

.tab-bar-item.active .tab-text {
  color: #A78BFA;
}

/* Active indicator pill */
.tab-bar-item.active::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #7C3AED, #38BDF8);
  border-radius: 0 0 4rpx 4rpx;
}

.tab-icon {
  width: 48rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

/* Active icon glow */
.tab-bar-item.active .tab-icon::after {
  content: '';
  position: absolute;
  inset: -6rpx;
  border-radius: 50%;
  background: rgba(139, 92, 246, 0.12);
}

/* Hourglass icon */
.icon-hourglass {
  width: 28rpx; height: 36rpx;
  display: flex; flex-direction: column; align-items: center;
}
.hourglass-top {
  width: 0; height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-top: 14rpx solid #475569;
  transition: border-top-color 0.2s;
}
.tab-bar-item.active .hourglass-top { border-top-color: #8B5CF6; }

.hourglass-mid {
  width: 3rpx; height: 8rpx;
  background: #475569;
  transition: background 0.2s;
}
.tab-bar-item.active .hourglass-mid { background: #8B5CF6; }

.hourglass-bot {
  width: 0; height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-bottom: 14rpx solid #475569;
  transition: border-bottom-color 0.2s;
}
.tab-bar-item.active .hourglass-bot { border-bottom-color: #38BDF8; }

/* Calendar icon */
.icon-calendar {
  width: 32rpx; height: 34rpx;
  border: 2rpx solid #475569;
  border-radius: 7rpx;
  overflow: hidden;
  transition: border-color 0.2s;
}
.tab-bar-item.active .icon-calendar { border-color: #8B5CF6; }

.cal-top {
  background: #475569;
  height: 11rpx;
  display: flex; align-items: center; justify-content: space-around;
  padding: 0 4rpx;
  transition: background 0.2s;
}
.tab-bar-item.active .cal-top { background: #8B5CF6; }

.cal-dot { width: 4rpx; height: 4rpx; background: rgba(7,11,24,0.8); border-radius: 50%; }

.cal-body { padding: 4rpx; display: flex; flex-direction: column; gap: 3rpx; }
.cal-line { height: 3rpx; background: #475569; border-radius: 2rpx; transition: background 0.2s; }
.tab-bar-item.active .cal-line { background: #A78BFA; }
.cal-line.short { width: 65%; }

/* Profile icon */
.icon-profile { display: flex; flex-direction: column; align-items: center; gap: 3rpx; }
.profile-head {
  width: 18rpx; height: 18rpx; border-radius: 50%;
  background: #475569; transition: background 0.2s;
}
.tab-bar-item.active .profile-head { background: #8B5CF6; }

.profile-body {
  width: 28rpx; height: 13rpx; border-radius: 7rpx 7rpx 0 0;
  background: #475569; transition: background 0.2s;
}
.tab-bar-item.active .profile-body { background: #8B5CF6; }
